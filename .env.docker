# =============================================================================
# Docker Environment Configuration
# =============================================================================
# Copy this file to .env.docker or .env before running docker-compose
# Adjust the values according to your deployment environment
# =============================================================================

# -----------------------------------------------------------------------------
# Host Configuration
# -----------------------------------------------------------------------------
# Port to expose on the host machine (default: 80)
# Change this if port 80 is already in use
HOST_PORT=80

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Docker Network API URL - Frontend will call backend through Docker network
# The frontend container will use this internal URL
# Format: http://<backend-container-name>:<port>/api
VITE_API_URL=http://worksy-backend:8080/api

# Public API URL (optional - for browser direct access if needed)
# This is the URL that browser will use (if different from internal)
# VITE_API_URL_PUBLIC=http://your-server-ip:8080/api

# -----------------------------------------------------------------------------
# Third-Party Services
# -----------------------------------------------------------------------------
# Geoapify Geocoding API Key (for location autocomplete)
# Get your API key at: https://myprojects.geoapify.com/
# Leave empty if not using geocoding features
VITE_GEOAPIFY_API_KEY=

# -----------------------------------------------------------------------------
# Timezone (Optional)
# -----------------------------------------------------------------------------
# Set the container timezone (default: UTC)
TZ=UTC

# -----------------------------------------------------------------------------
# Docker Registry (Optional - for pushing images)
# -----------------------------------------------------------------------------
# Example: docker.io/yourusername/worksy-frontend
# Example: ghcr.io/yourorg/worksy-frontend
DOCKER_REGISTRY=

# Image tag (default: latest)
DOCKER_IMAGE_TAG=latest
