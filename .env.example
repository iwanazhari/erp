# API Configuration
# Copy this file to .env and adjust the values

# Production URL
VITE_API_URL=https://worksy-production.up.railway.app/api

# Development URL (for local backend testing)
# VITE_API_URL=http://localhost:15320/api

# Geoapify Geocoding API (for location autocomplete)
# Get your API key at: https://myprojects.geoapify.com/
VITE_GEOAPIFY_API_KEY=your_api_key_here
