# API Configuration
# Copy this file to .env and adjust the values

# Production URL - Backend container name: worksy-backend, port: 15320
VITE_API_URL=http://worksy-backend:15320/api

# Alternative: Jika backend tidak di network yang sama, gunakan:
# VITE_API_URL=http://host.docker.internal:15320/api

# Development URL (untuk local testing)
# VITE_API_URL=http://localhost:15320/api

# Geoapify Geocoding API (untuk location autocomplete)
# Get your API key at: https://myprojects.geoapify.com/
VITE_GEOAPIFY_API_KEY=your_api_key_here

# Docker Configuration
HOST_PORT=80
